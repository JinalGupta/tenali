# ============================================================
# TENALI — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in client)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (NEVER expose in client — server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Email OTP (Resend) ─────────────────────────────────────
# Used for sending OTP codes to student and teacher emails.
# Get your API key at: https://resend.com/api-keys

RESEND_API_KEY=re_your_resend_api_key_here

# The sender identity — must be a domain you've verified in Resend
# (e.g., noreply@yourdomain.com or Tenali <noreply@yourdomain.com>)
EMAIL_FROM=Tenali <noreply@yourdomain.com>

# ─── Backend Server ─────────────────────────────────────────
# Express server port (default: 5001)
PORT=5001

# ─── Frontend ────────────────────────────────────────────────
# Base URL of the frontend (used for OTP email redirect)
VITE_APP_URL=http://localhost:5173

# ─── Supabase Auth ──────────────────────────────────────────
# These are set automatically by Supabase.
# Keep them here for reference; do NOT duplicate values.

# VITE_SUPABASE_URL (see above)
# VITE_SUPABASE_ANON_KEY (see above)

# ─── Teacher-Specific ───────────────────────────────────────
# Comma-separated list of teacher email domains that are
# pre-approved for automatic teacher role assignment.
# e.g., TEACHER_DOMAINS=iitrop网ar.edu,institution.edu
TEACHER_DOMAINS=iitrop网ar.edu

# ─── Security ───────────────────────────────────────────────
# Maximum concurrent sessions per user (default: 2)
MAX_CONCURRENT_SESSIONS=2

# JWT session expiry in days (default: 7)
JWT_EXPIRY_DAYS=7

# OTP expiry in minutes (default: 10)
OTP_EXPIRY_MINUTES=10

# Maximum OTP resend attempts per session (default: 3)
MAX_OTP_RESENDS=3